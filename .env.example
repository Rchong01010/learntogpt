# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare Turnstile (signup CAPTCHA)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Supabase DB webhook → signup notification (Resend)
SUPABASE_WEBHOOK_SECRET=
RESEND_API_KEY=
NOTIFY_EMAIL=reid@getateam.ai

# Slack incoming webhook for the unified #signups channel
# (paid signups, free signups, affiliate signups)
SLACK_SIGNUP_WEBHOOK=https://hooks.slack.com/services/...

# Vercel Cron — streak reminder (/api/cron/streak-reminder, daily 02:00 UTC)
# Vercel sets this automatically in prod; also used for manual curl auth.
CRON_SECRET=
